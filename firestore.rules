rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Genel veriler: Herkes okuyabilir, kimse yazamaz.
    match /precious_metals/{metal} {
      allow read: if true;
      allow write: if false;
    }

    // Kullanıcıya özel veriler: Sadece oturum açmış ve kimliği eşleşen kullanıcı kendi verisini okuyabilir/yazabilir.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;

      // Kullanıcının kendi işlemlerini okumasına/yazmasına izin ver
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Kullanıcının kendi portföyünü okumasına/yazmasına izin ver
       match /portfolio/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Diğer tüm belgelere erişimi varsayılan olarak reddet (Güvenli başlangıç)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}