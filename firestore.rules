rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Public Data Rules ---
    // Anyone can read precious metals and history, nobody can write.
    match /precious_metals/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /precious_metals_history/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /market_analyses/{document} {
      allow read: if true;
      allow write: if false;
    }

    // --- User Data Rules ---
    // Users can read/write their own data.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Any document in a subcollection of a user's document.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
